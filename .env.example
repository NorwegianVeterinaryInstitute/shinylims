# Description: Example of .env file
# Usage: Copy this file to .env and fill in the values
# Required for accessing pinned data from the Posit API for local development

# Posit API credentials
POSIT_API_KEY=...
POSIT_SERVER_URL="https://connect.posit.vetinst.no/"

# LIMS API credentials
LIMS_BASE_URL=https://<your-clarity-host>/api/v2
LIMS_API_USER=<service-account-user>
LIMS_API_PASS=<service-account-password>

# Clarity Postgres credentials
CLARITY_PG_HOST=<your-clarity-postgres-host>
CLARITY_PG_PORT=5432
CLARITY_PG_DB=<clarity-database-name>
CLARITY_PG_USER=<read-only-user>
CLARITY_PG_PASSWORD=<read-only-password>
# Optional alternative to the fields above:
# CLARITY_PG_URL=postgresql+psycopg://user:password@host:5432/dbname

# Comma-separated sequencing process type ids used by the direct Postgres prototype.
# When this is set, fetch_sequencing_data() will use the Postgres sequencing path.
CLARITY_PG_SEQUENCING_TYPE_IDS=15

# Enable the direct Postgres projects path.
CLARITY_PG_PROJECTS_ENABLED=false

# Enable the direct Postgres samples path.
CLARITY_PG_SAMPLES_ENABLED=false
